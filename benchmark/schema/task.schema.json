{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECVEBench TaskInstance",
  "type": "object",
  "required": ["task_id", "ghsa_id", "codebase", "hints", "ground_truth"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique GHSA-level task identifier. Format: ecvebench-{project}-{n}. Difficulty is a runtime parameter, not part of the task id."
    },
    "ghsa_id": {
      "type": "string",
      "description": "Source GitHub Security Advisory ID",
      "pattern": "^GHSA-[0-9a-z]{4}-[0-9a-z]{4}-[0-9a-z]{4}$"
    },
    "codebase": {
      "type": "object",
      "required": ["repo", "language", "ecosystem", "commit"],
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string",
          "format": "uri",
          "description": "GitHub repository URL"
        },
        "language": {
          "type": "string",
          "description": "Primary language of the repository"
        },
        "ecosystem": {
          "type": "string",
          "description": "Package ecosystem (e.g. npm, pip, maven, go, composer, rust, nuget, rubygems)"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Full 40-character pre-patch SHA served to the agent"
        }
      }
    },
    "hints": {
      "type": "object",
      "description": "Map of difficulty level to the hint shown at that level. The harness projects exactly one of these into the agent input at runtime.",
      "required": ["L0"],
      "additionalProperties": false,
      "properties": {
        "L0": {
          "type": "null",
          "description": "L0 is pure discovery; no hint is shown."
        },
        "L1": {
          "type": "object",
          "description": "Vague localization hint pointing at a broad region of the codebase without revealing the vulnerability type or specific files/functions.",
          "required": ["area"],
          "additionalProperties": false,
          "properties": {
            "area": {
              "type": "string",
              "description": "Broad codebase area where the vulnerability lives (e.g. 'authentication middleware', 'API request handling layer'). No file paths, function names, or vulnerability details."
            }
          }
        },
        "L2": {
          "type": "object",
          "description": "Scrubbed CVE description. Describes the vulnerability type, mechanism, and impact without revealing location.",
          "required": ["description"],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "description": "Scrubbed vulnerability description. No file or function references."
            }
          }
        },
        "L3": {
          "type": "object",
          "description": "Combined hint: both the L1 localization area and the L2 CVE description.",
          "required": ["area", "description"],
          "additionalProperties": false,
          "properties": {
            "area": {
              "type": "string",
              "description": "Same localization hint as L1."
            },
            "description": {
              "type": "string",
              "description": "Same scrubbed CVE description as L2."
            }
          }
        }
      }
    },
    "ground_truth": {
      "type": "object",
      "required": ["vulnerable", "vuln_class", "cvss", "reason", "locations"],
      "additionalProperties": false,
      "properties": {
        "vulnerable": {
          "type": "boolean"
        },
        "vuln_class": {
          "type": "string",
          "enum": [
            "command-injection",
            "sql-injection",
            "xss",
            "buffer-overflow",
            "use-after-free",
            "path-traversal",
            "auth-bypass",
            "xxe",
            "insecure-deserialization",
            "crypto-weakness",
            "race-condition",
            "integer-overflow",
            "null-deref"
          ]
        },
        "cvss": {
          "oneOf": [
            { "type": "null" },
            { "type": "number", "minimum": 0.0, "maximum": 10.0 }
          ]
        },
        "reason": {
          "type": "string",
          "description": "Unscored. Human-readable explanation of the vulnerability."
        },
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file", "function"],
            "additionalProperties": false,
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative path from repo root"
              },
              "function": {
                "oneOf": [{ "type": "null" }, { "type": "string" }]
              }
            }
          }
        }
      }
    }
  }
}
